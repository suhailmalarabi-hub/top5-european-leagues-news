{
  "expo": {
    "name": "أخبار الدوريات الأوروبية",
    "slug": "european-leagues-news",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.totiis.europeannewsleagues",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a2744"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1a2744"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7650114689148142~1322307253",
          "iosAppId": "ca-app-pub-7650114689148142~1322307253"
        }
      ]
    ],
    "extra": {
      "admob": {
        "ios": {
          "appId": "ca-app-pub-7650114689148142~1322307253",
          "bannerId": "ca-app-pub-7650114689148142/5665936435",
          "interstitialId": "ca-app-pub-7650114689148142/8100528086",
          "nativeAdvancedId": "ca-app-pub-7650114689148142/9037145747"
        },
        "android": {
          "appId": "ca-app-pub-7650114689148142~1322307253",
          "bannerId": "ca-app-pub-7650114689148142/5665936435",
          "interstitialId": "ca-app-pub-7650114689148142/8100528086",
          "nativeAdvancedId": "ca-app-pub-7650114689148142/9037145747"
        }
      },
      "router": {},
      "eas": {
        "projectId": "ab93cd31-a658-42e1-bb8e-778a22755475"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "owner": "totiis"
  }
}
